{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "build": {
          "cmds": [
            "./mvnw clean package -DskipTests"
          ]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "java -jar target/*.jar",
    "restartPolicyType": "ON_FAILURE"
  }
}